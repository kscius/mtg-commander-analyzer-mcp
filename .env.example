# Copy to .env and fill in. Never commit .env.

# Required for build_deck_with_llm and optional LLM fallbacks (e.g. card tagging in analyze_deck)
OPENAI_API_KEY=

# Optional overrides (see src/core/llmConfig.ts)
# OPENAI_MODEL=gpt-4.1
# OPENAI_TEMPERATURE=0.7
# OPENAI_MAX_TOKENS=4096
# OPENAI_BASE_URL=https://api.openai.com/v1
