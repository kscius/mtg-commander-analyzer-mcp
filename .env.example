# Copy to .env and set your OpenAI API key for build enhancement.
# Get a key: https://platform.openai.com/api-keys

# Required for OpenAI category enhancement during build_deck_from_commander
OPENAI_API_KEY=sk-your-api-key-here

# Mazo completo + repair (if you add full-deck LLM tools later)
OPENAI_MODEL=gpt-5.4

# Clasificación / picks desde candidatos en cards.db
OPENAI_MODEL_FAST=gpt-5.4-nano

# Opcional: builds premium
# OPENAI_MODEL_PREMIUM=gpt-5.5

# Opcional: agente con tools (fase futura)
# OPENAI_MODEL_AGENT=gpt-5.4-mini

# Optional: Temperature for LLM responses (0.0-2.0, default: 0.7)
OPENAI_TEMPERATURE=0.7

# Optional: Max tokens for LLM response (default: 4096)
OPENAI_MAX_TOKENS=4096

# Optional: OpenAI-compatible API base URL
# OPENAI_BASE_URL=https://api.openai.com/v1

# Card data: npm run db:create && npm run db:import
