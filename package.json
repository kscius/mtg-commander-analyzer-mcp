{
  "name": "mtg-commander-analyzer-mcp",
  "version": "0.7.0",
  "description": "Open-source TypeScript library and MCP server for analyzing Magic: The Gathering Commander (EDH) decks",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/kscius/mtg-commander-analyzer-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/kscius/mtg-commander-analyzer-mcp/issues"
  },
  "homepage": "https://github.com/kscius/mtg-commander-analyzer-mcp#readme",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run src/**/*.integration.test.ts",
    "test:golden": "vitest run --config vitest.golden.config.ts",
    "test:mcp-smoke": "ts-node scripts/mcpSmokeTest.ts",
    "record:golden": "ts-node scripts/recordGoldenAnalyze.ts",
    "benchmark:decks": "ts-node scripts/benchmarkDecks.ts",
    "decks:download-moxfield": "ts-node scripts/downloadMoxfieldDecks.ts",
    "decks:user-style-profile": "ts-node scripts/printUserDeckStyleProfile.ts",
    "brackets:check-official": "ts-node scripts/checkBracketOfficialSources.ts",
    "brackets:check-official:quick": "ts-node scripts/checkBracketOfficialSources.ts -- --skip-moxfield",
    "dev": "ts-node src/mcp/server.ts",
    "mcp": "ts-node src/mcp/server.ts",
    "test:local": "ts-node src/testLocal.ts",
    "test:build": "ts-node src/testBuildLocal.ts",
    "test:e2e": "ts-node src/testEndToEnd.ts",
    "clean": "rimraf dist",
    "setup": "node -e \"console.log('Please run ./setup.sh (Linux/macOS) or .\\\\setup.ps1 (Windows) to complete setup')\"",
    "db:create": "ts-node src/scripts/createDatabase.ts",
    "db:create:keep": "ts-node src/scripts/createDatabase.ts -- --keep",
    "db:import": "ts-node src/scripts/importCards.ts",
    "db:import-rulings": "ts-node src/scripts/importRulings.ts",
    "db:tag": "ts-node src/scripts/tagCards.ts",
    "db:tag-stats": "ts-node src/scripts/dbTagStats.ts",
    "db:stats": "ts-node -e \"const db = require('./src/core/cardDatabase'); console.log(db.getDatabaseStats());\"",
    "postinstall": "npm rebuild better-sqlite3"
  },
  "keywords": [
    "mtg",
    "magic-the-gathering",
    "commander",
    "edh",
    "deck-analyzer",
    "deck-builder",
    "mcp",
    "model-context-protocol",
    "scryfall",
    "edhrec",
    "bracket",
    "typescript",
    "ai-tools"
  ],
  "author": "MTG Commander Analyzer MCP Contributors",
  "license": "MIT",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/stream-json": "^1.7.8",
    "playwright": "^1.60.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.3",
    "better-sqlite3": "^12.5.0",
    "dotenv": "^17.2.3",
    "openai": "^6.39.0",
    "stream-json": "^1.9.1",
    "zod": "^4.1.13"
  }
}
